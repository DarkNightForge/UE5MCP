# ── Unreal build artifacts ───────────────────────────────────────────────
Binaries/
Intermediate/
Saved/
DerivedDataCache/
*.VC.db
*.opensdf
*.sdf
*.sln
*.xcodeproj
*.xcworkspace
.vs/

# ── Agent / assistant local artifacts ────────────────────────────────────
# NOTE: these were previously kept only in this machine's global git excludes.
# They are re-declared here because this repo is public + contributor-facing:
# per-machine global excludes do NOT travel with clones, so without these a
# collaborator could commit agent artifacts. Do not remove.
.hermes/
.agent-cache/
**/.claude/settings.local.json

# ── Personal time-tracking (local only, not part of the plugin) ───────────
.wakatime-project

# ── Build artifacts (generic) ────────────────────────────────────────────
build/
dist/
out/
bin/
obj/

# ── Large/generated assets and local exports ─────────────────────────────
*.zip
*.7z
*.rar
*.tar
*.tar.gz
*.tmp
*.log

# ── Python ───────────────────────────────────────────────────────────────
__pycache__/
*.py[cod]
.venv/
venv/
.env
.env.*
!.env.example
.pytest_cache/

# ── Node / web tooling ───────────────────────────────────────────────────
node_modules/
.next/
.vite/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# ── IDE/editor local state ───────────────────────────────────────────────
.vscode/settings.json
.idea/
*.swp
*.swo
.DS_Store
